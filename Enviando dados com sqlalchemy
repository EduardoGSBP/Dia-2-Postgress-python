# Importação da biblioteca Pandas para manipulação de dados
import pandas as pd

# Configura o Pandas para exibir todas as colunas do DataFrame
pd.set_option('display.max_columns', None)

# Caminho do arquivo JSON de origem
caminho_do_arquivo = r"C:\Users\Eduardo\OneDrive\Documentos\Curso\Arquivos\01. Postgree\Origem de dados\V_OCORRENCIA_AMPLA.json"

# Leitura do arquivo JSON com encoding adequado
df = pd.read_json(caminho_do_arquivo, encoding='utf-8-sig')

# Visualização inicial dos dados
df.head(3)


# ---------------------- TRATAMENTO DE DADOS ----------------------

# Lista de colunas relevantes para o projeto
colunas = [
    "Numero_da_Ocorrencia",
    "Classificacao_da_Ocorrência",
    "Data_da_Ocorrencia",
    "Municipio",
    "UF",
    "Regiao",
    "Nome_do_Fabricante",
    "Modelo"
]

# Filtra o DataFrame mantendo apenas as colunas selecionadas
df = df[colunas]

# Renomeia a coluna removendo o acento para padronização
df.rename(
    columns={'Classificacao_da_Ocorrência': 'Classificacao_da_Ocorrencia'},
    inplace=True
)

# Visualiza o DataFrame após tratamento
df.head()


# ---------------------- VALIDAÇÃO DOS DADOS ----------------------

# Verifica os tipos de dados das colunas
df.dtypes


# ---------------------- CONEXÃO COM BANCO ----------------------

# Importa recursos do SQLAlchemy
from sqlalchemy import create_engine, Integer, Date, VARCHAR

# Parâmetros de conexão com o banco PostgreSQL
dbname   = 'python'
user     = 'postgres'
password = '*******'
host     = 'localhost'
port     = '5432'

# Cria a string de conexão
conexao_str = f'postgresql://{user}:{password}@{host}:{port}/{dbname}'

# Cria o engine de conexão com o banco
engine = create_engine(conexao_str)


# ---------------------- CARGA DE DADOS ----------------------

# Nome da tabela no banco
nome_tabela = 'anac_sqlalchemy'

# Envia o DataFrame para o PostgreSQL
df.to_sql(
    nome_tabela,
    engine,
    index=False,              # Não envia o índice do DataFrame
    if_exists='replace',      # Sobrescreve a tabela se já existir
    dtype={                   # Define tipos das colunas no banco
        'Numero_da_Ocorrencia': Integer,
        'Classificacao_da_Ocorrencia': VARCHAR(50),
        'Data_da_Ocorrencia': Date
    }
)

# Observação:
# if_exists pode ser:
# - 'replace' → apaga e recria a tabela
# - 'append' → adiciona novos dados
# - 'fail' → gera erro se a tabela existir


# ---------------------- FINALIZAÇÃO ----------------------

# Fecha a conexão com o banco liberando recursos
engine.dispose()
